JWT_EXPIRES_IN=1h
ENCRYPTION_KEY=playground-encryption-key-32-chars-ok
BYPASS_2FA=true
FINCO_API_URL=http://localhost:3000/api/v1/mock-finco
FINCO_CLIENT_ID=mock-client-id
FINCO_CLIENT_SECRET=mock-client-secret
FINCO_API_KEY=mock-api-key
FINCO_ENVIRONMENT=sandbox
FINCO_ACCOUNT_ID=mock-account-001
FINCO_CLABE=012345678901234567
FINCO_INSTRUMENT_ID=mock-instrument-001
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@playground.local
DEFAULT_PROVIDER=mock
ENABLE_STP=false
ENABLE_FINCO=false
MOCK_MODE=true
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
